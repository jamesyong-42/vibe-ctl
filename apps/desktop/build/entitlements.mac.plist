<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- V8 JIT requires writable+executable memory. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Needed for Electron's DYLD_INSERT_LIBRARIES helper at spawn time. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>

  <!-- Loading third-party native modules (truffle-napi, node-pty, sqlite)
       under Hardened Runtime requires library validation off. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- Mesh network: outbound to peers, inbound for reverse proxy. -->
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- Users pick project directories via native file pickers. -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
