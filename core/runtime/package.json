{
  "name": "@vibe-ctl/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kernel-utility": {
      "import": "./dist/kernel-utility.js",
      "default": "./dist/kernel-utility.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@jamesyong42/infinite-canvas": "^1.0.0",
    "@jamesyong42/reactive-ecs": "^0.1.1",
    "@vibe-ctl/plugin-api": "workspace:*",
    "@vibecook/truffle": "^0.4.2",
    "chokidar": "^4.0.0",
    "comlink": "^4.4.2",
    "pino": "^9.5.0",
    "pino-roll": "^4.0.0",
    "semver": "^7.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/semver": "^7.5.0",
    "@vibe-ctl/tsconfig": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
