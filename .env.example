# vibe-ctl environment variables
# Copy this file to .env.local and adjust as needed. .env.local is gitignored.
#
# For VITE_* vars: Vite auto-loads .env.local on dev/build — they work as-is.
# For non-VITE vars (install-time, shell-level): use `pnpm install:local` /
# `pnpm dev:local` helpers, or install direnv + .envrc for auto-loading.

# ─── Monorepo linking ────────────────────────────────────────────────────────
# Link to sibling checkouts of @vibecook/truffle, @jamesyong42/infinite-canvas,
# @jamesyong42/reactive-ecs, etc. instead of resolving from the npm registry.
# See .pnpmfile.cjs for the link targets.
#
# Must be set at `pnpm install` time — not a runtime flag. Use:
#   pnpm install:local       (one-shot via package.json alias)
#   VIBE_LINK_LOCAL=1 pnpm install    (manual)
#   direnv + .envrc          (auto, personal setup)
#
# Do NOT commit a lockfile generated with this set — it contains absolute
# paths that break CI.
VIBE_LINK_LOCAL=0

# ─── Renderer (Vite) ─────────────────────────────────────────────────────────
# Force the onboarding flow to replay regardless of the
# `vibe-ctl.onboarded` localStorage flag. Session-only — dropping the var
# restores normal behaviour on the next launch.
#
# Vite auto-loads this from .env.local, or use:
#   pnpm dev:first-run    (one-shot via package.json alias)
VITE_VIBE_FORCE_FIRST_RUN=0
