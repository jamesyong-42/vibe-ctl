{
  "name": "vibe-ctl-plugin-registry-tools",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Publishing + validation tools for the vibe-ctl plugin registry.",
  "type": "module",
  "bin": {
    "vibe-ctl-plugin-registry": "./bin/index.mjs"
  },
  "main": "./dist/index.js",
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@vibe-ctl/extension-api": "workspace:*",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2",
    "semver": "^7.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.5.0",
    "@vibe-ctl/tsconfig": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
