{
  "$schema": "https://vibe-ctl.dev/schemas/plugin/v1.json",
  "id": "@vibe-ctl/plugin-dynamic-island",
  "name": "Dynamic Island",
  "version": "0.1.0",
  "apiVersion": "^1.0.0",
  "description": "macOS notch helper. Spawns the Swift NotchHelper binary and mirrors approval / agent status into the dynamic island surface.",
  "author": { "name": "vibe-ctl" },
  "license": "MIT",
  "icon": "./assets/icon.svg",
  "executionContext": "split",
  "entry": { "main": "./dist/main.js", "renderer": "./dist/renderer.js" },
  "eagerActivation": true,
  "engines": { "vibe-ctl": "^1.0.0", "platform": ["darwin"] },
  "provides": {},
  "dependencies": {},
  "optionalDependencies": {
    "notifications": "^1.0.0",
    "claude-code": "^1.0.0"
  },
  "waitForReady": [],
  "sync": {
    "settings": true,
    "data": []
  },
  "permissions": ["filesystem.state"],
  "hostProvided": [
    "@vibe-ctl/extension-api",
    "react",
    "react-dom",
    "@jamesyong42/infinite-canvas",
    "@jamesyong42/reactive-ecs",
    "@vibecook/truffle"
  ]
}
