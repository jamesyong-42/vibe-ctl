{
  "$schema": "https://vibe-ctl.dev/schemas/plugin/v1.json",
  "id": "@vibe-ctl/plugin-project-manager",
  "name": "Project Manager",
  "version": "0.1.0",
  "apiVersion": "^1.0.0",
  "description": "Project tree and grouping. Discovers projects via the claude-code service and exposes a typed `projects` service.",
  "author": { "name": "vibe-ctl" },
  "license": "MIT",
  "icon": "./assets/icon.svg",
  "executionContext": "renderer",
  "entry": "./dist/index.js",
  "eagerActivation": true,
  "engines": { "vibe-ctl": "^1.0.0" },
  "provides": { "projects": "1.0.0" },
  "dependencies": {},
  "optionalDependencies": {
    "claude-code": "^1.0.0"
  },
  "waitForReady": [],
  "sync": {
    "settings": true,
    "data": []
  },
  "permissions": [],
  "hostProvided": [
    "@vibe-ctl/extension-api",
    "react",
    "react-dom",
    "@jamesyong42/infinite-canvas",
    "@jamesyong42/reactive-ecs"
  ]
}
